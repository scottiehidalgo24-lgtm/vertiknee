    <div class="guarantee-badges">
      <div class="guarantee-badge"><div class="guarantee-badge-icon">🚚</div><div class="guarantee-badge-text">Spedizione Tracciata</div></div>
      <div class="guarantee-badge"><div class="guarantee-badge-icon">🔒</div><div class="guarantee-badge-text">Pagamento Sicuro</div></div>
      <div class="guarantee-badge"><div class="guarantee-badge-icon">🔄</div><div class="guarantee-badge-text">Prova 30 Giorni</div></div>
      <div class="guarantee-badge"><div class="guarantee-badge-icon">📏</div><div class="guarantee-badge-text">Cambio Taglia Semplice</div></div>
    </div>
  </div>
</section>
