<style>
.guarantee { padding:80px 0;background:var(--brand-white);text-align:center; }
.guarantee h2 { font-family:'Montserrat',sans-serif;font-size:clamp(24px,4vw,28px);font-weight:800;color:var(--brand-dark);margin-bottom:16px; }
.guarantee p { font-size:15px;color:var(--brand-gray);max-width:560px;margin:0 auto 36px;line-height:1.7; }
.guarantee-badges { display:flex;justify-content:center;gap:20px;flex-wrap:wrap; }
.guarantee-badge { background:var(--brand-light);border-radius:8px;padding:20px 24px;text-align:center;min-width:140px; }
.guarantee-badge-icon { font-size:28px;margin-bottom:8px; }
.guarantee-badge-text { font-size:12px;font-weight:700;color:var(--brand-dark);text-transform:uppercase;letter-spacing:.5px; }
@media (max-width:768px) { .guarantee { padding:48px 0; } }
</style>

