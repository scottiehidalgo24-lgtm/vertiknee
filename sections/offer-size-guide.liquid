<style>
.offer { padding:80px 0;background:var(--brand-light); }
.offer h2 { text-align:center;font-family:'Montserrat',sans-serif;font-size:clamp(26px,4vw,30px);font-weight:800;color:var(--brand-dark);margin-bottom:8px; }
.offer-sub { text-align:center;font-size:15px;color:var(--brand-gray);margin-bottom:48px; }
.packs { display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:700px;margin:0 auto 48px; }
.pack { background:var(--brand-white);border:2px solid var(--brand-border);border-radius:var(--radius);padding:32px 24px;text-align:center;transition:border-color .3s,box-shadow .3s;position:relative;cursor:pointer; }
.pack:hover { border-color:var(--brand-blue);box-shadow:0 4px 16px rgba(31,105,240,.12); }
.pack.best { border-color:var(--brand-blue);background:#f0f6ff; }
.pack-badge { position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--brand-blue);color:#fff;padding:4px 16px;border-radius:12px;font-size:12px;font-weight:700; }
.pack-qty { font-family:'Montserrat',sans-serif;font-size:24px;font-weight:900;margin-bottom:4px;color:var(--brand-dark); }
.pack-label { font-size:13px;color:var(--brand-gray);margin-bottom:12px; }
.pack-price { font-family:'Montserrat',sans-serif;font-size:28px;font-weight:900;color:var(--brand-blue); }
.pack-save { font-size:12px;color:#059669;font-weight:600;margin-top:4px; }

.size-guide { max-width:600px;margin:0 auto; }
.size-guide h3 { font-family:'Montserrat',sans-serif;font-size:22px;font-weight:800;color:var(--brand-dark);text-align:center;margin-bottom:8px; }
.size-guide-sub { text-align:center;font-size:14px;color:var(--brand-gray);margin-bottom:24px; }
.size-img { background:var(--brand-dark);border-radius:var(--radius);padding:24px;text-align:center;color:#fff;margin-bottom:20px;font-size:14px; }
.size-table { width:100%;border-collapse:collapse;margin-bottom:20px;font-size:14px; }
.size-table th { background:var(--brand-dark);color:#fff;padding:10px;font-weight:600; }
.size-table td { padding:10px;text-align:center;border-bottom:1px solid var(--brand-border); }
.size-tip { font-size:13px;color:var(--brand-gray);text-align:center;margin-bottom:24px;line-height:1.5; }
.offer-cta { display:block;max-width:400px;margin:0 auto;text-align:center;background:var(--brand-blue);color:#fff;padding:18px 44px;border-radius:8px;font-size:17px;font-weight:700;text-decoration:none;box-shadow:0 4px 16px rgba(31,105,240,.3);transition:transform .2s; }
.offer-cta:hover { transform:translateY(-2px); }
.offer-info { text-align:center;font-size:13px;color:var(--brand-gray);margin-top:16px;display:flex;justify-content:center;gap:16px;flex-wrap:wrap; }
@media (max-width:768px) { .packs { grid-template-columns:1fr; } .offer { padding:48px 0; } }
</style>

<section id="offer" class="offer">
  <div class="container">
    <h2>PREPARATI PRIMA DELLA<br>PROSSIMA ESCURSIONE.</h2>
    <p class="offer-sub">Non aspettare che sia il sentiero a ricordarti quanto può essere impegnativa una discesa.</p>

    <div class="packs">
      <div class="pack">
        <div class="pack-qty">1 GINOCCHIERA</div>
        <div class="pack-label">Per un solo ginocchio</div>
        <div class="pack-price">€24,99</div>
      </div>
      <div class="pack best">
        <div class="pack-badge">BEST VALUE</div>
        <div class="pack-qty">2 GINOCCHIERE</div>
        <div class="pack-label">Per affrontare il percorso con supporto su entrambi i lati</div>
        <div class="pack-price">€39,99</div>
        <div class="pack-save">Risparmia il 20%</div>
      </div>
    </div>

    <div id="size-guide" class="size-guide">
      <h3>TROVA LA TAGLIA GIUSTA</h3>
      <p class="size-guide-sub">In meno di un minuto.</p>
      <div class="size-img">
        Misura la circonferenza del ginocchio<br>10 cm sopra la rotula
      </div>
      <table class="size-table">
        <tr><th>Taglia</th><th>Circonferenza</th></tr>
        <tr><td>M</td><td>34–38 cm</td></tr>
        <tr><td>L</td><td>38–42 cm</td></tr>
        <tr><td>XL</td><td>42–46 cm</td></tr>
      </table>
      <p class="size-tip">📏 Se sei tra due taglie, scegli quella più piccola per una compressione più sicura.<br>✅ Compatibile con ginocchio destro e sinistro.</p>

      <a href="/products/vertiknee-ginocchiera" class="offer-cta">SCEGLI LA TUA TAGLIA</a>
      <div class="offer-info">
        <span>🚚 Spedizione tracciata · 7–11 giorni</span>
        <span>📦 1 o 2 pezzi inclusi</span>
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Offer + Size Guide","settings":[],"presets":[{"name":"Offer + Size Guide"}]}{% endschema %}