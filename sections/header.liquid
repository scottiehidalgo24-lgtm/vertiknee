<style>
.header { display:flex;justify-content:space-between;align-items:center;padding:14px 24px;border-bottom:1px solid var(--brand-border);background:var(--brand-white);position:sticky;top:0;z-index:100; }
.header-logo { height:34px; }
.header-logo img { height:100%; }
.header-nav { display:flex;align-items:center;gap:20px; }
.header-nav a { font-size:13px;font-weight:500;color:var(--brand-gray);text-decoration:none;transition:color .2s; }
.header-nav a:hover { color:var(--brand-dark); }
.header-cta { background:var(--brand-blue);color:var(--brand-white);border:none;padding:10px 22px;border-radius:6px;font-weight:700;font-size:13px;text-decoration:none;transition:opacity .2s;white-space:nowrap; }
.header-cta:hover { opacity:.9; }
@media (max-width:768px) {
  .header-nav { display:none; }
  .header { padding:12px 16px; }
  .header-cta { padding:8px 16px;font-size:12px; }
}
</style>
<nav class="header">
  <a href="/" class="header-logo">
    <img src="{{ 'logo-full-color.jpg' | asset_url }}" alt="VertiKnee">
  </a>
  <div class="header-nav">
    <a href="#how-it-works">COME FUNZIONA</a>
    <a href="#size-guide">GUIDA TAGLIE</a>
    <a href="#faq">FAQ</a>
  </div>
  <a href="#offer" class="header-cta">SCEGLI LA TUA TAGLIA</a>
</nav>
{% schema %}{"name":"Header","settings":[],"presets":[{"name":"Header"}]}{% endschema %}