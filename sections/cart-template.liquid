<style>
.cart { max-width:800px;margin:0 auto;padding:60px 24px; }
.cart h1 { font-family:'Montserrat',sans-serif;font-size:28px;font-weight:800;color:var(--brand-dark);margin-bottom:32px; }
.cart-empty { text-align:center;padding:60px 0; }
.cart-empty h2 { font-size:20px;color:var(--brand-dark);margin-bottom:16px; }
.cart-empty p { color:var(--brand-gray);margin-bottom:24px; }
.cart-empty a { display:inline-block;background:var(--brand-blue);color:#fff;padding:14px 32px;border-radius:8px;font-weight:700;text-decoration:none; }
.cart-items { border-top:1px solid var(--brand-border); }
.cart-item { display:flex;gap:16px;align-items:center;padding:20px 0;border-bottom:1px solid var(--brand-border); }
.cart-item-img { width:80px;height:80px;border-radius:8px;overflow:hidden;background:var(--brand-light);flex-shrink:0; }
.cart-item-img img { width:100%;height:100%;object-fit:cover; }
.cart-item-info { flex:1; }
.cart-item-info h3 { font-size:15px;font-weight:600;color:var(--brand-dark);margin-bottom:4px; }
.cart-item-info .cart-variant { font-size:13px;color:var(--brand-gray); }
.cart-item-qty { display:flex;align-items:center;gap:8px; }
.cart-item-qty input { width:60px;padding:8px;border:1px solid var(--brand-border);border-radius:6px;text-align:center;font-size:14px; }
.cart-item-qty button { background:var(--brand-blue);color:#fff;border:none;padding:8px 12px;border-radius:6px;font-size:13px;cursor:pointer; }
.cart-item-price { font-weight:700;font-size:16px;color:var(--brand-dark);min-width:70px;text-align:right; }
.cart-item-remove { color:var(--brand-gray);text-decoration:underline;font-size:12px;cursor:pointer; }
.cart-footer { margin-top:32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px; }
.cart-total { font-size:20px;font-weight:800;color:var(--brand-dark); }
.cart-checkout { background:var(--brand-blue);color:#fff;border:none;padding:16px 40px;border-radius:8px;font-size:18px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-block; }
.cart-note { text-align:center;margin-top:16px;font-size:13px;color:var(--brand-gray); }
.cart-note img { height:24px;vertical-align:middle;margin:0 4px; }
@media (max-width:768px) {
  .cart-item { flex-wrap:wrap; }
  .cart-item-price { text-align:left; }
}
</style>

<section class="cart">
  <h1>IL TUO CARRELLO</h1>
  <!-- CART_V4_DISCOUNT -->

  {% if cart.item_count > 0 %}
  <form action="/cart" method="post">
    <div class="cart-items">
      {% for item in cart.items %}
      <div class="cart-item">
        <div class="cart-item-img">
          <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title }}">
        </div>
        <div class="cart-item-info">
          <h3>{{ item.product.title }}</h3>
          <p class="cart-variant">{{ item.variant.title }}</p>
          <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item-remove">Rimuovi</a>
        </div>
        <div class="cart-item-qty">
          <input type="number" name="updates[]" value="{{ item.quantity }}" min="1">
        </div>
        <div class="cart-item-price">{{ item.final_line_price | money }}</div>
      </div>
      {% endfor %}
    </div>

    <div class="cart-footer">
      {% if cart.item_count >= 1 %}
        {% assign total_qty = 0 %}
        {% for item in cart.items %}
          {% assign total_qty = total_qty | plus: item.quantity %}
        {% endfor %}
        {% if total_qty >= 2 %}
          {% assign discount_amount = cart.total_price | times: 20 | divided_by: 100 %}
          {% assign discounted_total = cart.total_price | minus: discount_amount %}
          <div style="width:100%;background:#ecfdf5;border:1px solid #a7f3d0;border-radius:8px;padding:16px;margin-bottom:16px;text-align:center;">
            🎉 <strong>20% DI SCONTO APPLICATO!</strong> acquistando 2+ pezzi<br>
            <span style="font-size:14px;color:#059669;">Risparmi {{ discount_amount | money }} — paghi solo {{ discounted_total | money }} al checkout</span>
          </div>
        {% else %}
          <div style="width:100%;background:#f0f7ff;border:1px solid #bdd7f5;border-radius:8px;padding:12px;margin-bottom:16px;text-align:center;font-size:13px;color:var(--brand-blue);">
            💡 Aggiungi un altro pezzo e ottieni il <strong>20% di sconto</strong>!
          </div>
        {% endif %}
      {% endif %}
      <div class="cart-total">Totale: {{ cart.total_price | money }}</div>
      <button type="submit" name="checkout" class="cart-checkout">VAI AL PAGAMENTO</button>
    </div>
  </form>

  <div class="cart-note">
    🔒 Pagamento sicuro · Spedizione tracciata · Reso 30 giorni
  </div>

  {% else %}
  <div class="cart-empty">
    <h2>Il tuo carrello è vuoto</h2>
    <p>Scegli la tua ginocchiera e torna in azione.</p>
    <a href="/products/vertiknee-ginocchiera">VEDI IL PRODOTTO</a>
  </div>
  {% endif %}
</section>
{% schema %}{"name":"Cart Template","settings":[],"presets":[{"name":"Cart"}]}{% endschema %}
