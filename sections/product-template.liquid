<style>
.pd { display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;padding:80px 0; }
.pd-gallery { display:flex;flex-direction:column;gap:12px; }
.pd-main-img { aspect-ratio:1;background:var(--brand-light);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;overflow:hidden; }
.pd-main-img img { width:100%;height:100%;object-fit:cover; }
.pd-thumbs { display:flex;gap:8px; }
.pd-thumb { width:64px;height:64px;border-radius:6px;overflow:hidden;border:2px solid transparent;cursor:pointer;transition:border-color .2s; }
.pd-thumb:hover,.pd-thumb.active { border-color:var(--brand-blue); }
.pd-thumb img { width:100%;height:100%;object-fit:cover; }
.pd-info { display:flex;flex-direction:column;gap:16px; }
.pd-info h2 { font-family:'Montserrat',sans-serif;font-size:30px;font-weight:800;color:var(--brand-dark);line-height:1.2; }
.pd-rating { display:flex;align-items:center;gap:8px;font-size:14px;color:var(--brand-gray); }
.pd-stars { color:#f59e0b; }
.pd-price-row { display:flex;align-items:center;gap:12px; }
.pd-price { font-size:32px;font-weight:900;color:var(--brand-blue); }
.pd-old-price { font-size:18px;color:var(--brand-gray);text-decoration:line-through; }
.pd-badge { background:#ecfdf5;color:#059669;padding:4px 12px;border-radius:4px;font-size:13px;font-weight:600; }
.pd-desc { font-size:15px;color:var(--brand-gray);line-height:1.7; }
.pd-variant { margin-top:8px; }
.pd-variant label { font-size:13px;font-weight:600;color:var(--brand-dark);display:block;margin-bottom:6px; }
.pd-variant select { width:100%;padding:14px 16px;border:1px solid var(--brand-border);border-radius:8px;font-size:16px;color:var(--brand-dark);background:var(--brand-white); }
.pd-qty-row { display:flex;align-items:center;gap:12px; }
.pd-qty { border:1px solid var(--brand-border);border-radius:8px;padding:14px;font-size:16px;width:70px;text-align:center; }
.pd-cart { flex:1;background:var(--brand-blue);color:#fff;border:none;padding:16px 32px;border-radius:8px;font-size:18px;font-weight:700;cursor:pointer;transition:opacity .2s; }
.pd-cart:hover { opacity:.9; }
.pd-badges { display:flex;gap:16px;margin-top:8px;flex-wrap:wrap; }
.pd-badge-item { display:flex;align-items:center;gap:6px;font-size:12px;color:var(--brand-gray); }
.pd-checklist { margin-top:8px; }
.pd-checklist p { font-size:14px;margin-bottom:4px;color:var(--brand-dark); }
.pd-bundle-note { background:var(--brand-light);padding:16px;border-radius:8px;font-size:14px;color:var(--brand-dark);margin-top:8px; }
.pd-bundle-note strong { color:var(--brand-blue); }
@media (max-width:768px) { .pd { grid-template-columns:1fr;gap:32px;padding:40px 0; } }
</style>

<section class="container pd">
  <div class="pd-gallery">
    <div class="pd-main-img">
      <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" id="mainImg">
    </div>
    <div class="pd-thumbs">
      {% for image in product.images %}
      <div class="pd-thumb {% if forloop.first %}active{% endif %}" onclick="document.getElementById('mainImg').src='{{ image | img_url: '800x' }}'">
        <img src="{{ image | img_url: '120x' }}" alt="{{ image.alt }}">
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="pd-info">
    <div>
      <div class="pd-rating">
        <span class="pd-stars">★★★★★</span> 4.8 · Oltre 5.000 ordini
      </div>
      <h2>{{ product.title }}</h2>
    </div>
    <div class="pd-price-row">
      <span class="pd-price">{{ product.selected_or_first_available_variant.price | money }}</span>
      <span class="pd-old-price">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
      {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}<span class="pd-badge">RISPARMIA 50%</span>{% endif %}
    </div>

    <p class="pd-desc">{{ product.description | strip_html | truncate: 300 }}</p>

    <form method="post" action="/cart/add">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      {% if product.variants.size > 1 %}
      {% assign colors = '' %}
      {% for variant in product.variants %}
        {% assign parts = variant.title | split: ' / ' %}
        {% assign vcolor = parts[0] %}
        {% unless colors contains vcolor %}
          {% assign colors = colors | append: vcolor | append: '|' %}
        {% endunless %}
      {% endfor %}
      {% assign color_list = colors | split: '|' %}
      {% assign has_colors = false %}
      {% if color_list.size > 3 %}{% assign has_colors = true %}{% endif %}
      {% if has_colors == false and product.options.size > 1 %}{% assign has_colors = true %}{% endif %}
      {% if has_colors %}
      <div class="pd-variant" style="display:flex;flex-direction:column;gap:16px;">
        {% assign current_variant_title = product.selected_or_first_available_variant.title | split: ' / ' %}
        {% assign current_color = current_variant_title[0] %}
        {% assign current_size = current_variant_title[1] %}
        <div>
          <label>COLORE: <strong id="colorLabel">{{ current_color }}</strong></label>
          <div style="display:flex;gap:10px;margin-top:8px;flex-wrap:wrap;">
            {% for color_val in color_list %}
            {% if color_val != '' %}
            <button type="button" onclick="selectColor('{{ color_val }}')" class="color-swatch" data-color="{{ color_val }}" style="width:44px;height:44px;border-radius:50%;border:3px solid var(--brand-border);background:{% if color_val == 'Nero' %}#1a1a1a{% elsif color_val == 'Blu' %}#1F69F0{% elsif color_val == 'Rosso' %}#e53e3e{% else %}#ccc{% endif %};cursor:pointer;transition:border-color .2s;" title="{{ color_val }}"></button>
            {% endif %}
            {% endfor %}
          </div>
        </div>
        <div>
          <label for="variant-select">TAGLIA</label>
          <select id="variant-select" name="id" onchange="this.form.submit()">
            {% for variant in product.variants %}
            {% assign vtitle_parts = variant.title | split: ' / ' %}
            <option value="{{ variant.id }}" data-color="{{ vtitle_parts[0] }}" data-size="{{ vtitle_parts[1] }}">
              {{ vtitle_parts[1] }} — {{ variant.price | money }}
            </option>
            {% endfor %}
          </select>
        </div>
      </div>
      <script>
        (function() {
          var currentColor = '{{ current_color }}';
          var sw = document.querySelector('.color-swatch[data-color="' + currentColor + '"]');
          if (sw) sw.style.borderColor = 'var(--brand-blue)';
        })();
        function selectColor(color) {
          document.querySelectorAll('.color-swatch').forEach(function(b) { b.style.borderColor = 'var(--brand-border)'; });
          var clicked = document.querySelector('.color-swatch[data-color="' + color + '"]');
          if (clicked) clicked.style.borderColor = 'var(--brand-blue)';
          var sel = document.getElementById('variant-select');
          var currentSize = sel.selectedOptions[0].getAttribute('data-size');
          for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].getAttribute('data-size') === currentSize && sel.options[i].getAttribute('data-color') === color) {
              sel.value = sel.options[i].value;
              break;
            }
          }
          document.getElementById('colorLabel').textContent = color;
        }
      </script>
      {% else %}
      <div class="pd-variant" style="display:flex;flex-direction:column;gap:16px;">
        <div>
          <label for="variant-select">{{ product.options[0].name | upcase }}</label>
          <select id="variant-select" name="id" onchange="this.form.submit()">
            {% for variant in product.variants %}
            <option value="{{ variant.id }}">
              {{ variant.option1 }} — {{ variant.price | money }}
            </option>
            {% endfor %}
          </select>
        </div>
      </div>
      {% endif %}
      {% endif %}

      <div class="pd-qty-row" style="margin-top:16px;">
        <input type="number" name="quantity" value="1" min="1" class="pd-qty">
        <button type="submit" class="pd-cart">AGGIUNGI AL CARRELLO</button>
      </div>
    </form>

    <div class="pd-bundle-note">
      💡 <strong>Best Value:</strong> acquista 2 pezzi e risparmia il 20%. Aggiungi quantità 2 nel carrello.
    </div>

    <div class="pd-badges">
      <div class="pd-badge-item">🔄 Prova 30 Giorni</div>
      <div class="pd-badge-item">📦 Spedizione Tracciata</div>
      <div class="pd-badge-item">🔒 Pagamento Sicuro</div>
    </div>

    <div class="pd-checklist">
      <p>✅ Supporto mirato in discesa</p>
      <p>✅ Grip antiscivolo in silicone</p>
      <p>✅ Tessuto traspirante e leggero</p>
      <p>✅ Compatta — sta nello zaino</p>
    </div>
  </div>
</section>
{% schema %}{"name":"Product Template","settings":[],"presets":[{"name":"Product"}]}{% endschema %}
