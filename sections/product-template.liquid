<style>
.pd { display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;padding:80px 0; }
.pd-img { aspect-ratio:1;background:var(--brand-light);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;overflow:hidden; }
.pd-img img { max-width:85%;max-height:85%;object-fit:contain; }
.pd-info { display:flex;flex-direction:column;gap:20px; }
.pd-info h2 { font-family:'Montserrat',sans-serif;font-size:34px;font-weight:800;color:var(--brand-dark); }
.pd-rating { display:flex;align-items:center;gap:8px; }
.pd-stars { color:#f59e0b;font-size:16px; }
.pd-rating-count { color:var(--brand-gray);font-size:14px; }
.pd-price-row { display:flex;align-items:center;gap:12px; }
.pd-price { font-size:32px;font-weight:900;color:var(--brand-blue); }
.pd-old-price { font-size:18px;color:var(--brand-gray);text-decoration:line-through; }
.pd-badge { background:#ecfdf5;color:#059669;padding:4px 12px;border-radius:4px;font-size:13px;font-weight:600; }
.pd-desc { font-size:15px;color:var(--brand-gray);line-height:1.7; }
.bundle-opts { display:flex;gap:8px;flex-wrap:wrap; }
.bundle-opt { background:var(--brand-white);border:1px solid var(--brand-border);padding:12px 18px;border-radius:8px;font-size:14px;cursor:pointer;transition:border-color .2s; }
.bundle-opt.best { border:2px solid var(--brand-blue);background:#eff6ff; }
.bundle-opt span { color:var(--brand-blue);font-size:12px;font-weight:600; }
.pd-buy { display:flex;gap:12px;align-items:center; }
.pd-qty { background:var(--brand-white);border:1px solid var(--brand-border);color:var(--brand-dark);padding:14px 20px;border-radius:8px;font-size:16px;width:70px;text-align:center; }
.pd-cart { flex:1;background:var(--brand-blue);color:#fff;border:none;padding:16px 32px;border-radius:8px;font-size:18px;font-weight:700;cursor:pointer;transition:opacity .2s; }
.pd-cart:hover { opacity:.9; }
.pd-badges { display:flex;gap:16px;margin-top:8px; }
.pd-badge-item { display:flex;align-items:center;gap:6px;font-size:12px;color:var(--brand-gray); }
.pd-checklist { margin-top:12px; }
.pd-checklist p { font-size:14px;margin-bottom:6px;color:var(--brand-dark); }
@media (max-width:768px) { .pd { grid-template-columns:1fr;gap:32px; } .pd-buy { flex-direction:column; } }
</style>

<section class="container pd">
  <div class="pd-img">
    <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}">
  </div>
  <div class="pd-info">
    <h2>{{ product.title }}</h2>
    <div class="pd-rating">
      <span class="pd-stars">★★★★★</span>
      <span class="pd-rating-count">4.7 · 11,364 reviews · 50,000+ sold</span>
    </div>
    <div class="pd-price-row">
      <span class="pd-price">{{ product.price | money }}</span>
      <span class="pd-old-price">{{ product.compare_at_price | money }}</span>
      {% if product.compare_at_price > product.price %}<span class="pd-badge">SAVE 50%</span>{% endif %}
    </div>
    <p class="pd-desc">{{ product.description | strip_html | truncate: 250 }}</p>

    <div>
      <p style="font-size:13px;font-weight:600;color:var(--brand-dark);margin-bottom:8px;">BUNDLE & SAVE:</p>
      <div class="bundle-opts">
        <div class="bundle-opt">1 × {{ product.price | money }}</div>
        <div class="bundle-opt best">2 × SAVE 20%</div>
        <div class="bundle-opt">3 × SAVE 30%</div>
      </div>
    </div>

    <div class="pd-buy">
      <form method="post" action="/cart/add" style="display:flex;gap:12px;width:100%;">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="number" name="quantity" value="1" min="1" class="pd-qty">
        <button type="submit" class="pd-cart">ADD TO CART</button>
      </form>
    </div>

    <div class="pd-badges">
      <div class="pd-badge-item">🔄 30-Day Guarantee</div>
      <div class="pd-badge-item">📦 Free Shipping</div>
      <div class="pd-badge-item">🔒 Secure Checkout</div>
    </div>

    <div class="pd-checklist">
      <p>✅ 3D Anatomic Compression</p>
      <p>✅ Anti-Slip Silicone Grip</p>
      <p>✅ Breathable Tech Fabric</p>
      <p>✅ Ultralight — 80g</p>
    </div>
  </div>
</section>
{% schema %}{"name":"Product Template","settings":[],"presets":[{"name":"Product"}]}{% endschema %}
