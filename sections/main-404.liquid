<style>
.not-found { display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:48px 24px; }
.not-found h1 { font-family:'Montserrat',sans-serif;font-size:clamp(48px,8vw,96px);font-weight:900;color:var(--brand-blue); }
.not-found h2 { font-family:'Inter',sans-serif;font-size:24px;color:var(--brand-dark);margin-bottom:8px; }
.not-found p { color:var(--brand-gray);margin-bottom:32px;font-size:16px; }
.not-found a { background:var(--brand-blue);color:#fff;padding:14px 36px;border-radius:8px;font-weight:700;text-decoration:none; }
</style>
<div class="not-found container">
  <h1>404</h1>
  <h2>Trail Not Found</h2>
  <p>Looks like this path doesn't exist. Let's get you back on track.</p>
  <a href="/">Back to VertiKnee</a>
</div>
{% schema %}{"name":"404","settings":[],"presets":[{"name":"404"}]}{% endschema %}
