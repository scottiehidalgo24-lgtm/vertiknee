<style>
.hero { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; padding: 80px 0; }
.hero-content h1 { font-size: 52px; font-weight: 900; line-height: 1.1; letter-spacing: -1px; margin-bottom: 16px; }
.hero-content h1 span { color: var(--accent); display: block; }
.hero-tagline { font-size: 16px; color: var(--text-dim); margin-bottom: 32px; letter-spacing: 4px; text-transform: uppercase; }
.hero-bullets { display: flex; gap: 24px; margin-bottom: 40px; }
.hero-bullet { display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 500; }
.hero-bullet-icon { width: 20px; height: 20px; border-radius: 50%; background: var(--green); display: flex; align-items: center; justify-content: center; font-size: 10px; }
.hero-img { width: 100%; aspect-ratio: 1; background: var(--surface); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid var(--border); }
.hero-img img { max-width: 90%; max-height: 90%; object-fit: contain; }
.cta-btn { display: inline-block; background: var(--accent); color: #fff; padding: 16px 48px; border-radius: 8px; font-size: 18px; font-weight: 700; text-decoration: none; transition: transform 0.2s; }
.cta-btn:hover { transform: translateY(-2px); }
.cta-price { display: inline-block; margin-left: 20px; font-size: 14px; color: var(--text-dim); }
.cta-strike { text-decoration: line-through; margin-right: 8px; }
@media (max-width: 768px) { .hero { grid-template-columns: 1fr; padding: 40px 0; gap: 32px; } .hero-content h1 { font-size: 32px; } }
</style>

<section class="container hero">
  <div class="hero-content">
    <h1><span>GO HIGHER.</span> GO FARTHER. WITHOUT PAIN.</h1>
    <div class="hero-tagline">Professional Knee Support for Trekkers</div>
    <div class="hero-bullets">
      <div class="hero-bullet"><span class="hero-bullet-icon">✓</span> 3D Compression</div>
      <div class="hero-bullet"><span class="hero-bullet-icon">✓</span> Ultralight 80g</div>
      <div class="hero-bullet"><span class="hero-bullet-icon">✓</span> Anti-Slip Grip</div>
    </div>
    <div>
      <a href="/products/knee-sleeve" class="cta-btn">GET YOURS — €24.99</a>
      <span class="cta-price"><span class="cta-strike">€49.99</span> 50% OFF</span>
    </div>
  </div>
  <div class="hero-img">
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | img_url: '800x' }}" alt="VertiKnee Knee Support">
    {% else %}
      <span style="font-size:48px;">⛰️</span>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
