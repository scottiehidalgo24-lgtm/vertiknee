<style>
.hero { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;padding:80px 0; }
.hero-content h1 { font-family:'Montserrat',sans-serif;font-size:clamp(34px,5vw,54px);font-weight:900;line-height:1.05;letter-spacing:-1.5px;margin-bottom:12px;color:var(--brand-dark); }
.hero-content h1 .blue { color:var(--brand-blue); }
.hero-sub { font-size:18px;color:var(--brand-dark);font-weight:500;margin-bottom:16px;line-height:1.4; }
.hero-desc { font-size:15px;color:var(--brand-gray);margin-bottom:28px;line-height:1.6;max-width:480px; }
.hero-bullets { display:flex;gap:20px;margin-bottom:32px;flex-wrap:wrap; }
.hero-bullet { display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;color:var(--brand-dark); }
.hero-bullet svg { width:18px;height:18px;color:var(--brand-blue);flex-shrink:0; }
.cta-row { display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:14px; }
.cta-btn { display:inline-block;background:var(--brand-blue);color:#fff;padding:18px 44px;border-radius:8px;font-size:17px;font-weight:700;text-decoration:none;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 16px rgba(31,105,240,.3);text-align:center; }
.cta-btn:hover { transform:translateY(-2px);box-shadow:0 8px 24px rgba(31,105,240,.4); }
.trust-line { font-size:13px;color:var(--brand-gray);display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:12px; }
.trust-line span { display:flex;align-items:center;gap:4px; }
.hero-social { font-size:14px;color:var(--brand-dark);font-weight:600;margin-bottom:12px; }
.hero-season { font-size:13px;color:var(--brand-blue);font-weight:600;margin-bottom:4px; }
.hero-media { width:100%;aspect-ratio:1;background:var(--brand-light);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;overflow:hidden; }
.hero-media img { width:100%;height:100%;object-fit:cover; }
@media (max-width:768px) {
  .hero { grid-template-columns:1fr;padding:40px 0 48px;gap:32px; }
  .hero-content h1 { font-size:30px; }
  .hero-sub { font-size:16px; }
  .cta-btn { width:100%;text-align:center; }
  .hero-media { aspect-ratio:4/3; }
}
</style>

<section class="container hero">
  <div class="hero-content">
    <h1><span class="blue">LA VETTA È SOLO</span><br>METÀ DEL PERCORSO.</h1>
    <p class="hero-sub">Non lasciare che sia la discesa a decidere fin dove puoi arrivare.</p>
    <p class="hero-desc">VertiKnee ti offre il supporto che serve proprio quando il sentiero mette maggiormente alla prova le tue ginocchia.</p>
    <div class="hero-bullets">
      <div class="hero-bullet"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Supporto Mirato</div>
      <div class="hero-bullet"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Grip Antiscivolo</div>
      <div class="hero-bullet"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Comfort in Movimento</div>
    </div>
    <div class="cta-row">
      <a href="#offer" class="cta-btn">PREPARATI ALLA DISCESA — DA €24,99</a>
    </div>
    <div class="trust-line">
      <span>🚚 Spedizione Tracciata</span>
      <span style="color:rgba(0,0,0,.15);">·</span>
      <span>🔄 Prova 30 Giorni</span>
      <span style="color:rgba(0,0,0,.15);">·</span>
      <span>📏 Cambio Taglia Semplice</span>
    </div>
    <div class="hero-social">
      ⭐ 4.8 · Oltre 5.000 ordini registrati
    </div>
    <div class="hero-season">
      🏔️ La stagione dei trekking è già iniziata. Preparati prima della prossima escursione.
    </div>
  </div>
  <div class="hero-media">
    <img src="{{ 'hero.jpg' | asset_url }}" alt="Escursionista con VertiKnee in montagna">
  </div>
</section>
{% schema %}{"name":"Hero","settings":[],"presets":[{"name":"Hero"}]}{% endschema %}