<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gift Card</title>
</head>
<body style="font-family: sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f5f7fa;">
  <div style="background: white; padding: 48px; border-radius: 16px; text-align: center; max-width: 480px; box-shadow: 0 4px 24px rgba(0,0,0,.08);">
    <h1 style="font-size: 24px; color: #101723;">🎁 Gift Card</h1>
    <p style="color: #6b7280;">{{ gift_card.balance | money }} available</p>
    {% if gift_card.expired? %}
      <p style="color: #ef4444;">This gift card has expired.</p>
    {% endif %}
  </div>
</body>
</html>
